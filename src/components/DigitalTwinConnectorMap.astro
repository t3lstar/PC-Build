---
import digitalTwin from '../../data/digital-twin/build.json';

const motherboardConnectors = digitalTwin.connectors.filter((connector) => connector.componentId === 'motherboard');
const locationsById = new Map(digitalTwin.locations.map((location) => [location.id, location]));

const placements = new Map([
  ['cpu-eps-header', { x: 10, y: 6, width: 20, height: 9 }],
  ['cpu-fan-header', { x: 62, y: 7, width: 13, height: 8 }],
  ['cpu-opt-header', { x: 76, y: 7, width: 13, height: 8 }],
  ['fan4-pump-header', { x: 76, y: 17, width: 13, height: 8 }],
  ['memory-slot-a2', { x: 64, y: 29, width: 8, height: 31 }],
  ['memory-slot-b2', { x: 74, y: 29, width: 8, height: 31 }],
  ['atx-24-pin-header', { x: 88, y: 37, width: 8, height: 24 }],
  ['front-usb-a-header', { x: 86, y: 64, width: 10, height: 8 }],
  ['front-usb-c-header', { x: 86, y: 74, width: 10, height: 8 }],
  ['m2a-cpu-slot', { x: 36, y: 38, width: 23, height: 7 }],
  ['primary-pcie-x16-slot', { x: 22, y: 66, width: 52, height: 7 }],
  ['front-panel-header', { x: 70, y: 88, width: 20, height: 7 }],
  ['front-audio-header', { x: 10, y: 88, width: 18, height: 7 }],
]);

const connectorPoints = motherboardConnectors
  .map((connector) => {
    const placement = placements.get(connector.id);
    const location = locationsById.get(connector.locationId);
    return placement
      ? {
          ...connector,
          ...placement,
          zone: location?.label ?? connector.locationId,
          fallback: location?.staticFallback ?? 'Connector zone.',
        }
      : undefined;
  })
  .filter(Boolean);

const firstConnector = connectorPoints[0];
---

<section class="pc-connector-map" aria-labelledby="pc-connector-map-heading">
  <div class="pc-case-view__header">
    <div>
      <h2 id="pc-connector-map-heading">Motherboard Connector Map</h2>
      <p>
        Schematic map of the build-critical motherboard connectors. Connector identities and use
        are source-backed; exact interactive coordinates remain schematic until board-photo
        verification is added.
      </p>
    </div>
    <span class="pc-status">connector data</span>
  </div>

  <div class="pc-connector-map__layout">
    <div class="pc-connector-map__board" aria-label="Schematic motherboard connector map">
      <svg class="pc-connector-map__svg" viewBox="0 0 100 100" role="img" aria-labelledby="connector-svg-title connector-svg-desc">
        <title id="connector-svg-title">Schematic motherboard connector map</title>
        <desc id="connector-svg-desc">
          Simplified motherboard map showing CPU socket, memory slots, M.2 slot, primary PCIe slot,
          power headers, cooling headers, USB headers, front panel, and audio headers.
        </desc>
        <rect class="pc-connector-map__pcb" x="5" y="4" width="90" height="92" rx="2" />
        <rect class="pc-connector-map__socket" x="35" y="20" width="20" height="18" rx="2" />
        <text class="pc-connector-map__label" x="45" y="31" text-anchor="middle">AM5</text>
        <rect class="pc-connector-map__chipset" x="48" y="74" width="17" height="14" rx="2" />
        <text class="pc-connector-map__label" x="56.5" y="82.5" text-anchor="middle">B850</text>
      </svg>

      {
        connectorPoints.map((connector) => (
          <button
            class={`pc-connector-map__pin pc-connector-map__pin--${connector.kind}`}
            type="button"
            style={`--x:${connector.x};--y:${connector.y};--w:${connector.width};--h:${connector.height};`}
            data-label={connector.label}
            data-kind={connector.kind}
            data-zone={connector.zone}
            data-pin-label={connector.pinLabel ?? 'n/a'}
            data-verification={connector.evidence.state}
            data-fallback={connector.fallback}
            aria-describedby="pc-connector-map-selected"
          >
            <span>{connector.pinLabel ?? connector.label}</span>
          </button>
        ))
      }
    </div>

    {
      firstConnector && (
        <aside class="pc-case-view__details" id="pc-connector-map-selected" aria-live="polite">
          <h3>{firstConnector.label}</h3>
          <dl>
            <div>
              <dt>Kind</dt>
              <dd>{firstConnector.kind}</dd>
            </div>
            <div>
              <dt>Zone</dt>
              <dd>{firstConnector.zone}</dd>
            </div>
            <div>
              <dt>Pin label</dt>
              <dd>{firstConnector.pinLabel ?? 'n/a'}</dd>
            </div>
            <div>
              <dt>Verification</dt>
              <dd>{firstConnector.evidence.state}</dd>
            </div>
            <div>
              <dt>Fallback</dt>
              <dd>{firstConnector.fallback}</dd>
            </div>
          </dl>
        </aside>
      )
    }
  </div>

  <details class="pc-case-view__fallback">
    <summary>Static Connector List</summary>
    <ul>
      {
        connectorPoints.map((connector) => (
          <li>
            <strong>{connector.pinLabel ?? connector.label}</strong>: {connector.label}. Zone:
            {' '}{connector.zone}. Verification: {connector.evidence.state}.
          </li>
        ))
      }
    </ul>
  </details>
</section>

<script>
  const root = document.querySelector('.pc-connector-map');
  const details = root?.querySelector('.pc-case-view__details');
  const title = details?.querySelector('h3');
  const values = details?.querySelectorAll('dd');

  function setActive(button) {
    if (!details || !title || !values || values.length < 5) return;

    root?.querySelectorAll('.pc-connector-map__pin').forEach((item) => {
      item.setAttribute('aria-pressed', item === button ? 'true' : 'false');
    });

    title.textContent = button.dataset.label ?? '';
    values[0].textContent = button.dataset.kind ?? '';
    values[1].textContent = button.dataset.zone ?? '';
    values[2].textContent = button.dataset.pinLabel ?? '';
    values[3].textContent = button.dataset.verification ?? '';
    values[4].textContent = button.dataset.fallback ?? '';
  }

  root?.querySelectorAll('.pc-connector-map__pin').forEach((button, index) => {
    button.setAttribute('aria-pressed', index === 0 ? 'true' : 'false');
    button.addEventListener('click', () => setActive(button));
    button.addEventListener('focus', () => setActive(button));
  });
</script>
