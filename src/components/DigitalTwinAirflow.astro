---
import digitalTwin from '../../data/digital-twin/build.json';

const locationsById = new Map(digitalTwin.locations.map((location) => [location.id, location]));

const zones = digitalTwin.airflow.map((zone) => ({
  ...zone,
  location: locationsById.get(zone.locationId)?.label ?? zone.locationId,
}));
---

<section class="pc-airflow" aria-labelledby="pc-airflow-heading">
  <div class="pc-case-view__header">
    <div>
      <h2 id="pc-airflow-heading">Airflow Visualisation</h2>
      <p>
        Inspect the planned intake and exhaust pattern. The roles are verified for the static guide;
        final fan blade direction is still a physical pre-boot check.
      </p>
    </div>
    <span class="pc-status">airflow data</span>
  </div>

  <div class="pc-airflow__controls" aria-label="Airflow filter">
    <button type="button" data-filter="all" aria-pressed="true">All</button>
    <button type="button" data-filter="intake" aria-pressed="false">Intake</button>
    <button type="button" data-filter="exhaust" aria-pressed="false">Exhaust</button>
  </div>

  <div class="pc-airflow__layout">
    <div class="pc-airflow__stage" aria-label="Schematic airflow visualisation">
      <svg class="pc-airflow__svg" viewBox="0 0 100 100" role="img" aria-labelledby="airflow-svg-title airflow-svg-desc">
        <title id="airflow-svg-title">Schematic airflow pattern</title>
        <desc id="airflow-svg-desc">
          Bottom and side fans are planned as intake. The top 360mm radiator is planned as exhaust.
        </desc>
        <defs>
          <marker id="airflow-intake-arrow" markerWidth="5" markerHeight="5" refX="4" refY="2.5" orient="auto">
            <path d="M0 0 L5 2.5 L0 5 Z" fill="#2563eb" />
          </marker>
          <marker id="airflow-exhaust-arrow" markerWidth="5" markerHeight="5" refX="4" refY="2.5" orient="auto">
            <path d="M0 0 L5 2.5 L0 5 Z" fill="#dc2626" />
          </marker>
        </defs>
        <rect class="pc-case-view__shell" x="10" y="8" width="80" height="84" rx="3" />
        <rect class="pc-case-view__glass" x="22" y="20" width="56" height="58" rx="2" />
        <rect class="pc-airflow__radiator" x="28" y="12" width="44" height="8" rx="1" />
        <text class="pc-airflow__label" x="50" y="17.5" text-anchor="middle">Top radiator</text>
        <path class="pc-airflow__arrow pc-airflow__arrow--intake" data-direction="intake" d="M28 96 L28 82" />
        <path class="pc-airflow__arrow pc-airflow__arrow--intake" data-direction="intake" d="M50 96 L50 82" />
        <path class="pc-airflow__arrow pc-airflow__arrow--intake" data-direction="intake" d="M72 96 L72 82" />
        <path class="pc-airflow__arrow pc-airflow__arrow--intake" data-direction="intake" d="M98 39 L82 39" />
        <path class="pc-airflow__arrow pc-airflow__arrow--intake" data-direction="intake" d="M98 57 L82 57" />
        <path class="pc-airflow__arrow pc-airflow__arrow--exhaust" data-direction="exhaust" d="M50 3 L50 12" />
      </svg>
    </div>

    <div class="pc-airflow__zones">
      {
        zones.map((zone) => (
          <article data-direction={zone.direction}>
            <h3>{zone.label}</h3>
            <p>{zone.staticFallback}</p>
            <dl>
              <div>
                <dt>Location</dt>
                <dd>{zone.location}</dd>
              </div>
              <div>
                <dt>Direction</dt>
                <dd>{zone.direction}</dd>
              </div>
              <div>
                <dt>Verification</dt>
                <dd>{zone.evidence.state}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </div>

  <details class="pc-case-view__fallback">
    <summary>Static Airflow List</summary>
    <ul>
      {
        zones.map((zone) => (
          <li>
            <strong>{zone.label}</strong>: {zone.direction}. {zone.staticFallback} Verification:
            {' '}{zone.evidence.state}.
          </li>
        ))
      }
    </ul>
  </details>
</section>

<script>
  const root = document.querySelector('.pc-airflow');
  const buttons = root?.querySelectorAll('.pc-airflow__controls button');
  const arrows = root?.querySelectorAll('.pc-airflow__arrow');
  const cards = root?.querySelectorAll('.pc-airflow__zones article');

  function setFilter(filter) {
    buttons?.forEach((button) => {
      button.setAttribute('aria-pressed', button.getAttribute('data-filter') === filter ? 'true' : 'false');
    });

    arrows?.forEach((arrow) => {
      const matches = filter === 'all' || arrow.getAttribute('data-direction') === filter;
      arrow.setAttribute('data-muted', matches ? 'false' : 'true');
    });

    cards?.forEach((card) => {
      const matches = filter === 'all' || card.getAttribute('data-direction') === filter;
      card.toggleAttribute('hidden', !matches);
    });
  }

  buttons?.forEach((button) => {
    button.addEventListener('click', () => setFilter(button.getAttribute('data-filter') ?? 'all'));
  });
</script>
