{
  "globs": [
    "*.md",
    "milestones/**/*.md",
    "src/content/docs/**/*.md",
    "src/content/docs/**/*.mdx"
  ],
  "ignores": [
    "node_modules/**",
    "dist/**",
    "site/**",
    "build/**"
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": {
      "siblings_only": true
    },
    "MD033": false,
    "MD041": false
  }
}
